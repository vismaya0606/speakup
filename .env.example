# ── Required ──────────────────────────────────────────────────────────────────
# Your Google Gemini API key — get it free at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the model (default: gemini-2.0-flash-lite — free tier)
# GEMINI_MODEL=gemini-2.0-flash

# Secret token to protect the /api/conversations admin endpoint
# ADMIN_SECRET=your-secret-token-here

# Override storage directory (default: /tmp/speakup on Vercel)
# DATA_DIR=/tmp/speakup
