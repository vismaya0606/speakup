# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key — set this in Vercel project settings (never commit the real key)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Secret token to protect the /api/conversations admin endpoint
# ADMIN_SECRET=your-secret-token-here

# Override storage directory (default: /tmp/speakup on Vercel)
# DATA_DIR=/tmp/speakup
